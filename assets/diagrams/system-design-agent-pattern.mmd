flowchart LR
    U["User"] --> GW["Gateway + authentication"]
    GW --> O["Conversation orchestrator"]
    O --> LLM["LLM: untrusted planner"]
    O --> R["Policy retriever"]
    R --> IDX[("Derived policy index")]

    LLM -->|"Typed proposed action"| TG["Tool gateway"]
