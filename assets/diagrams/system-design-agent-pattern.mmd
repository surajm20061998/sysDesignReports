    PA --> ACT["Transactional action service"]
    ACT --> LEDGER[("Idempotency/action ledger")]

    TG --> O
    O --> CASE[("Conversation/case store")]
    O --> HUMAN["Human queue"]
    TG --> AUDIT[("Append-only audit log")]
